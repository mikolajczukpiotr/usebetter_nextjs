generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Required by @usebetterdev/tenant — do NOT add tenantId here
model Tenant {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String     @unique
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  users      User[]
  projects   Project[]
  categories Category[]

  @@map("tenants")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  email    String
  name     String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // tenant-scoped unique email (not global)
  @@unique([tenantId, email])
  @@map("users")
}

model Project {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  name     String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@map("projects")
}

model Category {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  name     String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@map("categories")
}

// Global table — no tenantId, no RLS
model GlobalConfig {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value String

  @@map("global_config")
}
